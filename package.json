{
  "name": "typed-route",
  "type": "module",
  "version": "0.4.0",
  "description": "Type-safe URL builder and matcher for fetch() calls. Extracts :param names at compile time, resolves base URLs from Vite/Deno/Bun/Node/browser, and matches URLs back into typed params via URLPattern. Zero dependencies.",
  "author": "Sebastian Nomme <sebastian.nomme@icloud.com>",
  "license": "MIT",
  "homepage": "https://github.com/bastianplsfix/typed-route#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bastianplsfix/typed-route.git"
  },
  "bugs": {
    "url": "https://github.com/bastianplsfix/typed-route/issues"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@typescript/native-preview": "7.0.0-dev.20260309.1",
    "bumpp": "^10.4.1",
    "typescript": "^5.9.3",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "vite-plus": "latest"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "npm@11.11.1"
}
